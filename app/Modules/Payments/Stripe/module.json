{
    "version": "1.0.0",
    "author": "Leezr",
    "provides_payment_driver": "stripe",
    "payment_module": {
        "name": "Stripe",
        "description": "Stripe integration for subscriptions and payments.",
        "supported_methods": ["card", "sepa_debit", "ideal", "bancontact"],
        "requires_credentials": true,
        "credential_fields": [
            {"key": "publishable_key", "label": "Publishable Key", "type": "text", "required": true},
            {"key": "secret_key", "label": "Secret Key", "type": "password", "required": true},
            {"key": "webhook_secret", "label": "Webhook Secret", "type": "password", "required": true}
        ],
        "icon": "tabler-brand-stripe"
    }
}
